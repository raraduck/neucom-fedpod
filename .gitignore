# =============================================================
# Artifacts — 학습 결과물 (폴더는 유지, 내용물은 제외)
# =============================================================

# 체크포인트 / 모델 가중치
states/*
!states/.gitkeep

# 학습 로그
logs/*
!logs/.gitkeep

# TensorBoard runs
runs/*
!runs/.gitkeep

# 분석 결과물 (summary.csv 제외)
analysis/results/*
!analysis/results/atlas/
analysis/results/atlas/*
!analysis/results/atlas/summary.csv
!analysis/results/seg_summary.csv
!analysis/results/report_summary.csv

# =============================================================
# 데이터 — 무거운 원본/전처리 데이터 (폴더 구조만 유지)
# =============================================================

# 원본 데이터 (fets240, fets128-1mm)
data/fets240/inst_00/*
data/fets240/inst_01/*

data/fets128-1mm/

# 전처리 결과 데이터
data/fets128/inst_00/*
data/fets128/inst_01/*

# MNI 정합 결과 (NIfTI + 변환행렬)
data/fets128-mni-reg/

# MNI registration 단계별 출력
data/fets240-step1-align/

# Atlas (XML 레이블 + NIfTI 모두 추적)
# !data/atlases/

# NIfTI 파일 전체 (data/ 하위 어디에 있어도)
data/**/*.nii.gz
data/**/*.nii
data/**/*.mat

# 단, atlases 폴더 전체는 추적 (MNI 템플릿 + HarvardOxford atlas 포함)
!data/atlases/**

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# =============================================================
# 가상환경
# =============================================================
.venv/
venv/
env/

# =============================================================
# Jupyter
# =============================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================
# 에디터 / OS
# =============================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
.cursor/

# =============================================================
# 환경 설정 / 시크릿
# =============================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# =============================================================
# 임시 파일
# =============================================================
*.tmp
*.bak
*.log
